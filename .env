# Mobile Money: Safaricom Daraja API (M-Pesa). Register a sandbox app at
# https://developer.safaricom.co.ke to get MPESA_CONSUMER_KEY/SECRET — until those are
# set, initiate_stk_push() raises a clear "not configured" error rather than failing
# oddly. MPESA_SHORTCODE/MPESA_PASSKEY: Daraja's public sandbox Buy Goods test
# shortcode+passkey from the developer portal's "Lipa Na M-Pesa Sandbox" page.
# MPESA_CALLBACK_BASE_URL must be a real public HTTPS URL for Daraja to reach (e.g. an
# ngrok tunnel during dev) — STK push requests will fail without it.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_BASE_URL=

# Production HTTPS (fontis/settings/production.py only — no effect in dev). Leave unset
# until a reverse proxy terminating TLS sits in front of Waitress; flip
# SECURE_SSL_REDIRECT/SESSION_COOKIE_SECURE/CSRF_COOKIE_SECURE to True and set
# CSRF_TRUSTED_ORIGINS (comma-separated, e.g. https://app.fontissprings.co.ke) once it does.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=
